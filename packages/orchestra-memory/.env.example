# orchestra-memory — server-side environment file (docker-compose.yml)
#
# This file configures the DOCKER SERVER only. Copy it to `.env` in this
# same directory (`cp .env.example .env`) before running `docker compose up`.
#
# Client-side vars (ORCHESTRA_MEMORY_URL, ORCHESTRA_MEMORY_TOKEN,
# ORCHESTRA_MEMORY_TIMEOUT_MS) are set in the environment of the machine
# running the local MCP client/hooks, NOT here — this .env file only ever
# reaches the container via docker-compose.yml. See the client-side setup
# docs (packages/orchestra/commands/memory-setup.md, once written) for those.

# --- Required -----------------------------------------------------------

# Bearer token the server requires on every /rpc request (Authorization:
# Bearer <token>). REQUIRED: mcp-server/src/serve.ts's
# createServeHttpServer() refuses to start (exit 1) when this is unset,
# because the container always listens on 0.0.0.0:8787 internally (only the
# HOST-side port mapping in docker-compose.yml is loopback-restricted) --
# an unauthenticated non-loopback bind would expose the whole memory
# database.
#
# Generate a strong random token, e.g.:
#   openssl rand -hex 32
#
# Never commit a real token. Leave this blank/placeholder in
# .env.example; put the real value only in your local (gitignored) .env.
ORCHESTRA_MEMORY_SERVER_TOKEN=

# --- Advanced overrides (rarely needed) ----------------------------------
#
# The image already bakes in sane defaults (see Dockerfile):
#   ORCHESTRA_MEMORY_LISTEN=0.0.0.0:8787   (internal bind; host exposure is
#                                            controlled by docker-compose.yml's
#                                            port mapping, not this var)
#   ORCHESTRA_MEMORY_DB_PATH=/data/graph.db (inside the /data named volume)
#
# Uncomment and set only if you have a specific reason to deviate --
# most setups should never need to touch these.

# ORCHESTRA_MEMORY_LISTEN=0.0.0.0:8787
# ORCHESTRA_MEMORY_DB_PATH=/data/graph.db
