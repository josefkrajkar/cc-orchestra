# Dependencies
node_modules/

# SQLite graph-memory database + rotated backups (runtime state, lives in ~/.claude)
*.db
*.db-shm
*.db-wal
backups/

# Runtime orchestration state / logs (NOT the .claude-plugin/ manifest dir)
.claude/

# OS cruft
.DS_Store

